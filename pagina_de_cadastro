<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Notícias</title>
</head>
<body>
    <header>
        <h1>Cadastro de Notícias</h1>
        <nav>
            <ul>
                <li><a href="index.html">Início</a></li>
                <li><a href="lista.html">Lista</a></li>
                <li><a href="cadastro.html">Cadastro</a></li>
                <li><a href="https://www.exemplo.com" target="_blank">Link Externo</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <form action="salvar_noticia.php" method="POST" enctype="multipart/form-data">
            <label for="categoria">Categoria:</label>
            <select name="categoria" id="categoria">
                <option value="frontend">Front-end</option>
                <option value="backend">Back-end</option>
            </select><br><br>

            <label for="titulo">Título:</label>
            <input type="text" id="titulo" name="titulo" required><br><br>

            <label for="data">Data:</label>
            <input type="date" id="data" name="data" required><br><br>

            <label for="texto">Texto:</label>
            <textarea id="texto" name="texto" required></textarea><br><br>

            <label for="foto">Foto:</label>
            <input type="file" id="foto" name="foto" accept="image/*" required><br><br>

            <input type="submit" value="Cadastrar">
        </form>
    </main>

    <footer>
        <p>Desenvolvido por: Seu Nome</p>
    </footer>
</body>
</html>
